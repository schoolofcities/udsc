{
  "version": 8,
  "glyphs": "https://schoolofcities.github.io/fonts/fonts/{fontstack}/{range}.pbf",
  "sources": {
    "osm": {
      "type": "vector",
      "tiles": ["https://vector.openstreetmap.org/shortbread_v1/{z}/{x}/{y}.mvt"]
    }
  },
  "layers": [
    { "id": "background", "type": "background", "paint": { "background-color": "#ffffff" } },
    {
      "id": "land_green",
      "type": "fill",
      "source": "osm",
      "source-layer": "land",
      "filter": ["match", ["get", "kind"], [
        "forest", "grass", "meadow", "orchard", "vineyard", "allotments",
        "cemetery", "grave_yard", "village_green", 
        "greenhouse_horticulture", "plant_nursery", "heath", "scrub",
        "grassland", "swamp", "bog", "string_bog", "wet_meadow", "marsh",
        "golf_course", "park", "garden", "playground", "miniature_golf"
      ], true, false],
      "paint": { "fill-color": "#e2f0d4", "fill-opacity": 1 }
    },
    {
      "id": "land_other",
      "type": "fill",
      "source": "osm",
      "source-layer": "land",
      "filter": ["match", ["get", "kind"], [
        "industrial", "commercial", "retail", "railway", "landfill", "quarry",
        "brownfield", "greenfield", "farmyard", "garages",
        "sand", "beach", "bare_rock", "scree", "shingle"
      ], true, false],
      "paint": { "fill-color": "#e8d4eb", "fill-opacity": 0.1 }
    },
    {
      "id": "land_residential",
      "type": "fill",
      "source": "osm",
      "source-layer": "land",
      "filter": ["==", ["get", "kind"], "residential"],
      "paint": { "fill-color": "#faf3c0", "fill-opacity": 0.05 }
    },
    {
      "id": "land_institutional",
      "type": "fill",
      "source": "osm",
      "source-layer": "sites",
      "minzoom": 14,
      "filter": ["match", ["get", "kind"], ["danger_area", "sports_centre", "university", "college", "school", "hospital", "prison"], true, false],
      "paint": { "fill-color": "#f2e4ec", "fill-opacity": 0.1 }
    },
    { "id": "water_lines", "type": "line", "source": "osm", "source-layer": "water_lines", "filter": ["==", "tunnel", false], "paint": { "line-color": "#B8DDEF", "line-width": ["interpolate", ["linear"], ["zoom"], 8, 1, 14, 4] } },
    { "id": "ocean", "type": "fill", "source": "osm", "source-layer": "ocean", "paint": { "fill-color": "#E3F4FB" } },
    { "id": "water_polygons", "type": "fill", "source": "osm", "source-layer": "water_polygons", "paint": { "fill-color": "#E3F4FB" } },
    { "id": "ocean_outline", "type": "line", "source": "osm", "source-layer": "ocean", "paint": { "line-color": "#B8DDEF", "line-width": 1 } },
    { "id": "water_polygons_outline", "type": "line", "source": "osm", "source-layer": "water_polygons", "paint": { "line-color": "#B8DDEF", "line-width": 1 } },
    { "id": "cycleways", "type": "line", "source": "osm", "source-layer": "streets", "minzoom": 14, "filter": ["match", ["get", "kind"], ["cycleway", "path", "footway"], true, false], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#d1d1d1", "line-width": 1 } },
    {
      "id": "streets_tunnels_casing",
      "type": "line",
      "source": "osm",
      "source-layer": "streets",
      "filter": ["all", ["==", ["get", "tunnel"], true], ["in", ["get", "kind"], ["literal", ["motorway", "trunk", "primary", "secondary", "tertiary", "unclassified", "residential", "busway", "bus_guideway", "living_street"]]]],
      "layout": { "line-cap": "butt", "line-join": "round" },
      "paint": {
        "line-color": "#d1d1d1",
        "line-dasharray": [2, 2],
        "line-width": ["interpolate", ["linear"], ["zoom"],
          8,  ["match", ["get", "kind"], ["motorway", "trunk"], 2, ["primary"], 3, 1],
          14, ["match", ["get", "kind"], ["motorway", "trunk"], 7, ["primary"], 5.5, ["secondary"], 4.5, ["tertiary"], 3.5, ["unclassified", "residential", "living_street", "busway", "bus_guideway"], 2.5, 1.5],
          15, ["match", ["get", "kind"], ["motorway", "trunk"], 14, ["primary"], 11, ["secondary"], 9, ["tertiary"], 7, ["unclassified", "residential", "living_street", "busway", "bus_guideway"], 5, 3]
        ]
      }
    },
    {
      "id": "streets_tunnels_fill",
      "type": "line",
      "source": "osm",
      "source-layer": "streets",
      "filter": ["all", ["==", ["get", "tunnel"], true], ["in", ["get", "kind"], ["literal", ["motorway", "trunk", "primary", "secondary", "tertiary", "unclassified", "residential", "busway", "bus_guideway", "living_street"]]]],
      "layout": { "line-cap": "butt", "line-join": "round" },
      "paint": {
        "line-color": "#ececec",
        "line-width": ["interpolate", ["linear"], ["zoom"],
          8,  ["match", ["get", "kind"], ["motorway", "trunk"], 1, ["primary"], 1.5, 0.5],
          14, ["match", ["get", "kind"], ["motorway", "trunk"], 5, ["primary"], 4, ["secondary"], 3, ["tertiary"], 2.5, ["unclassified", "residential", "living_street", "busway", "bus_guideway"], 1.5, 0.75],
          15, ["match", ["get", "kind"], ["motorway", "trunk"], 10, ["primary"], 8, ["secondary"], 6, ["tertiary"], 5, ["unclassified", "residential", "living_street", "busway", "bus_guideway"], 3, 1.5]
        ]
      }
    },
    {
      "id": "streets_casing",
      "type": "line",
      "source": "osm",
      "source-layer": "streets",
      "filter": ["all", ["!=", ["get", "tunnel"], true], ["!=", ["get", "bridge"], true], ["in", ["get", "kind"], ["literal", ["motorway", "trunk", "primary", "secondary", "tertiary", "unclassified", "residential", "busway", "bus_guideway", "living_street"]]]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#d1d1d1",
        "line-width": ["interpolate", ["linear"], ["zoom"],
          8,  ["match", ["get", "kind"], ["motorway", "trunk"], 2, ["primary"], 3, 1],
          12, ["match", ["get", "kind"], ["motorway", "trunk"], 2, ["primary"], 3, ["secondary"], 2.75, ["tertiary"], 2.25, ["unclassified", "residential", "living_street", "busway", "bus_guideway"], 1, 1],
          14, ["match", ["get", "kind"], ["motorway", "trunk"], 7, ["primary"], 5.5, ["secondary"], 4.5, ["tertiary"], 3.5, ["unclassified", "residential", "living_street", "busway", "bus_guideway"], 2.5, 1.5],
          15, ["match", ["get", "kind"], ["motorway", "trunk"], 14, ["primary"], 11, ["secondary"], 9, ["tertiary"], 7, ["unclassified", "residential", "living_street", "busway", "bus_guideway"], 5, 3]
        ]
      }
    },
    {
      "id": "streets_fill",
      "type": "line",
      "source": "osm",
      "source-layer": "streets",
      "filter": ["all", ["!=", ["get", "tunnel"], true], ["!=", ["get", "bridge"], true], ["in", ["get", "kind"], ["literal", ["motorway", "trunk", "primary", "secondary", "tertiary", "unclassified", "residential", "busway", "bus_guideway", "living_street"]]]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#e8e8e8",
        "line-width": ["interpolate", ["linear"], ["zoom"],
          8,  ["match", ["get", "kind"], ["motorway", "trunk"], 1, ["primary"], 1.5, 0.5],
          12, ["match", ["get", "kind"], ["motorway", "trunk"], 1, ["primary"], 1.5, ["secondary"], 1.75, ["tertiary"], 1.25, ["unclassified", "residential", "living_street", "busway", "bus_guideway"], 0.5, 0.5],
          14, ["match", ["get", "kind"], ["motorway", "trunk"], 5, ["primary"], 4, ["secondary"], 3, ["tertiary"], 2.5, ["unclassified", "residential", "living_street", "busway", "bus_guideway"], 1.5, 0.75],
          15, ["match", ["get", "kind"], ["motorway", "trunk"], 10, ["primary"], 8, ["secondary"], 6, ["tertiary"], 5, ["unclassified", "residential", "living_street", "busway", "bus_guideway"], 3, 1.5]
        ]
      }
    },
    {
      "id": "streets_bridges_casing",
      "type": "line",
      "source": "osm",
      "source-layer": "streets",
      "filter": ["all", ["==", ["get", "bridge"], true], ["in", ["get", "kind"], ["literal", ["motorway", "trunk", "primary", "secondary", "tertiary", "unclassified", "residential", "busway", "bus_guideway", "living_street"]]]],
      "layout": { "line-cap": "butt", "line-join": "round" },
      "paint": {
        "line-color": "#b2b2b2",
        "line-width": ["interpolate", ["linear"], ["zoom"],
          8,  ["match", ["get", "kind"], ["motorway", "trunk"], 2, ["primary"], 3, 1],
          14, ["match", ["get", "kind"], ["motorway", "trunk"], 7, ["primary"], 5.5, ["secondary"], 4.5, ["tertiary"], 3.5, ["unclassified", "residential", "living_street", "busway", "bus_guideway"], 2.5, 1.5],
          15, ["match", ["get", "kind"], ["motorway", "trunk"], 14, ["primary"], 11, ["secondary"], 9, ["tertiary"], 7, ["unclassified", "residential", "living_street", "busway", "bus_guideway"], 5, 3]
        ]
      }
    },
    {
      "id": "streets_bridges_fill",
      "type": "line",
      "source": "osm",
      "source-layer": "streets",
      "filter": ["all", ["==", ["get", "bridge"], true], ["in", ["get", "kind"], ["literal", ["motorway", "trunk", "primary", "secondary", "tertiary", "unclassified", "residential", "busway", "bus_guideway", "living_street"]]]],
      "layout": { "line-cap": "butt", "line-join": "round" },
      "paint": {
        "line-color": "#e8e8e8",
        "line-width": ["interpolate", ["linear"], ["zoom"],
          8,  ["match", ["get", "kind"], ["motorway", "trunk"], 1, ["primary"], 1.5, 0.5],
          14, ["match", ["get", "kind"], ["motorway", "trunk"], 5, ["primary"], 4, ["secondary"], 3, ["tertiary"], 2.5, ["unclassified", "residential", "living_street", "busway", "bus_guideway"], 1.5, 0.75],
          15, ["match", ["get", "kind"], ["motorway", "trunk"], 10, ["primary"], 8, ["secondary"], 6, ["tertiary"], 5, ["unclassified", "residential", "living_street", "busway", "bus_guideway"], 3, 1.5]
        ]
      }
    },
    {
      "id": "rail",
      "type": "line",
      "source": "osm",
      "source-layer": "streets",
      "minzoom": 8,
      "filter": ["==", ["get", "kind"], "rail"],
      "layout": { "line-cap": "butt", "line-join": "round" },
      "paint": {
        "line-color": "#bbbbbb",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.5, 14, 1],
        "line-dasharray": [6, 3]
      }
    },
    { "id": "streetcar", "type": "line", "source": "osm", "source-layer": "streets", "minzoom": 14, "filter": ["==", ["get", "kind"], "tram"], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#cc2200", "line-width": 0.5, "line-opacity": 0.5 } },
    { "id": "buildings", "type": "fill", "source": "osm", "source-layer": "buildings", "minzoom": 14, "paint": { "fill-color": "#f5f5f5" } },
    { "id": "buildings_outline", "type": "line", "source": "osm", "source-layer": "buildings", "minzoom": 14, "paint": { "line-color": "#d8d8d8", "line-width": 0.5 } },
    {
      "id": "water_polygons_labels_large",
      "type": "symbol",
      "source": "osm",
      "source-layer": "water_polygons_labels",
      "filter": [">=", ["get", "way_area"], 1350000],
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["Open Sans Italic"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10, 11, 16, 14],
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#5BA4C7",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    },
    {
      "id": "water_polygons_labels_small",
      "type": "symbol",
      "source": "osm",
      "source-layer": "water_polygons_labels",
      "minzoom": 14,
      "filter": ["<", ["get", "way_area"], 1350000],
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["Open Sans Italic"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 14, 11, 16, 14],
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#5BA4C7",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    },
    {
      "id": "water_lines_labels",
      "type": "symbol",
      "source": "osm",
      "source-layer": "water_lines_labels",
      "minzoom": 12,
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["Open Sans Italic"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 10, 16, 13],
        "symbol-placement": "line",
        "text-max-angle": 30
      },
      "paint": {
        "text-color": "#5BA4C7",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    },
    {
      "id": "road_labels_secondary_plus",
      "type": "symbol",
      "source": "osm",
      "source-layer": "street_labels",
      "minzoom": 10.5,
      "filter": ["match", ["get", "kind"], ["motorway", "trunk", "primary", "secondary"], true, false],
      "layout": {
        "text-field": ["let", "n", ["coalesce", ["get", "name_en"], ["get", "name"]],
          ["case",
            ["==", ["var", "n"], "Highway 401 Express"], "Highway 401",
            ["==", ["var", "n"], "Highway 401 Collector"], "Highway 401",
            ["var", "n"]
          ]
        ],
        "text-font": ["Open Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 9, 9, 13.5, 10, 14, 11, 16, 14],
        "symbol-placement": "line",
        "text-max-angle": 30,
        "text-padding": 10
      },
      "paint": {
        "text-color": "#666666",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "road_labels_tertiary",
      "type": "symbol",
      "source": "osm",
      "source-layer": "street_labels",
      "minzoom": 13,
      "filter": ["==", ["get", "kind"], "tertiary"],
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["Open Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 13, 10, 13.5, 10, 14, 11, 16, 13],
        "symbol-placement": "line",
        "text-max-angle": 30,
        "text-padding": 10
      },
      "paint": {
        "text-color": "#666666",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "road_labels_residential",
      "type": "symbol",
      "source": "osm",
      "source-layer": "street_labels",
      "minzoom": 14,
      "filter": ["in", ["get", "kind"], ["literal", ["residential", "unclassified", "living_street"]]],
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["Open Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 14, 10, 15, 11, 17, 13],
        "symbol-placement": "line",
        "text-max-angle": 30,
        "text-padding": 10
      },
      "paint": {
        "text-color": "#777777",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    },

    {
      "id": "place-labels",
      "type": "symbol",
      "source": "osm",
      "source-layer": "place_labels",
      "filter": ["in", ["get", "kind"], ["literal", ["city", "town", "suburb", "neighbourhood", "quarter"]]],
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["Open Sans Regular"],
        "text-size": [
          "match", ["get", "kind"],
          "city",          14,
          "town",          12,
          "suburb",        11,
          "neighbourhood", 10,
          "quarter",       10,
          10
        ],
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#444444",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    }
  ]
}
